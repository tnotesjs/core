{
  "name": "@tnotesjs/core",
  "version": "0.0.3",
  "description": "TNotes 知识库核心框架 —— 基于 VitePress 的笔记管理系统",
  "type": "module",
  "bin": {
    "tnotes": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vitepress/config": {
      "import": "./dist/vitepress/config/index.js"
    },
    "./vitepress/theme": {
      "types": "./vitepress/theme/index.ts",
      "import": "./vitepress/theme/index.ts"
    },
    "./vitepress/*": "./vitepress/*"
  },
  "files": [
    "dist/",
    "vitepress/",
    "types/"
  ],
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit -p tsconfig.build.json",
    "dev": "tsup --watch",
    "release": "node scripts/release.mjs"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "vitepress": "^1.6.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "echarts": "^6.0.0",
    "github-slugger": "^2.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mathjax3": "^4.3.2",
    "markdown-it-task-lists": "^2.1.1",
    "marked": "^15.0.11",
    "markmap-lib": "^0.18.12",
    "markmap-toolbar": "^0.18.12",
    "markmap-view": "^0.18.12",
    "mermaid": "^11.5.0",
    "sass-embedded": "^1.90.0",
    "swiper": "^11.2.1",
    "uuid": "^11.1.0",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tnotesjs/core"
  },
  "keywords": [
    "tnotes",
    "vitepress",
    "knowledge-base",
    "notes"
  ]
}
